generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Kegiatan {
  id               Int      @id @default(autoincrement())
  tanggal          DateTime @db.Date
  lokasi           String   @db.VarChar(200)
  kegiatan         String   @db.VarChar(200)
  penyerta         String   @db.Text
  kategori         String   @default("luar_gedung") @db.VarChar(15)
  subKategori      String?  @default("lainnya") @db.VarChar(20)
  isAutoGenerated  Boolean  @default(false)
  source           String   @default("manual") @db.VarChar(15)

  @@index([tanggal])
}

model HariLibur {
  id         Int      @id @default(autoincrement())
  tanggal    DateTime @unique @db.Date
  keterangan String   @db.VarChar(200)
  jenis      String   @default("nasional") @db.VarChar(15)
}